<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gasoline Monitor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .sort-icon svg {
            transition: transform 0.2s ease;
        }
    </style>
    <script>

        function filterStates(keyword) {
            keyword = keyword.toLowerCase();

            const rows = document.querySelectorAll('#stateTable tbody tr');

            rows.forEach(row => {
                const state = row.children[0].innerText.toLowerCase();

                if (state.includes(keyword)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
        let sortDirection = {};

        function getSortIcon(type) {
            if (type === 'asc') {
                return `
                <svg class="w-3 h-3 inline text-gray-700" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M5 12l5-5 5 5H5z"/>
                </svg>`;
            }
            if (type === 'desc') {
                return `
                <svg class="w-3 h-3 inline text-gray-700" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M5 8l5 5 5-5H5z"/>
                </svg>`;
            }
            return `
                <svg class="w-3 h-3 inline opacity-40" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M5 8l5-5 5 5H5zM5 12h10l-5 5-5-5z"/>
                </svg>`;
        }

        function sortTable(colIndex) {
            const table = document.getElementById("stateTable");
            const tbody = table.querySelector("tbody");
            const rows = Array.from(tbody.querySelectorAll("tr"));
            const headers = table.querySelectorAll("th");

            // reset tất cả icon
            headers.forEach(th => {
                const icon = th.querySelector(".sort-icon");
                if (icon) icon.innerHTML = getSortIcon('default');
            });

            // toggle
            sortDirection[colIndex] = !sortDirection[colIndex];
            const isAsc = sortDirection[colIndex];

            rows.sort((a, b) => {
                let valA = a.children[colIndex].innerText.trim();
                let valB = b.children[colIndex].innerText.trim();

                if (colIndex !== 0) {
                    valA = parseFloat(valA.replace(/[^\d.-]/g, ""));
                    valB = parseFloat(valB.replace(/[^\d.-]/g, ""));
                }

                if (valA < valB) return isAsc ? -1 : 1;
                if (valA > valB) return isAsc ? 1 : -1;
                return 0;
            });

            // set icon hiện tại
            const currentIcon = headers[colIndex].querySelector(".sort-icon");
            if (currentIcon) {
                currentIcon.innerHTML = getSortIcon(isAsc ? 'asc' : 'desc');
            }

            tbody.innerHTML = "";
            rows.forEach(row => tbody.appendChild(row));
        }
    </script>
</head>
<body class="bg-gray-100">

    <!-- Navbar -->
    <nav class="bg-blue-600 p-4 shadow-md">
        <div class="container mx-auto">
            <h1 class="text-white text-xl font-semibold">Giá xăng dầu hôm nay</h1>
        </div>
    </nav>

    <!-- Content -->
    <div class="container mx-auto mt-8 p-4">
        <div class="bg-white shadow-md rounded-2xl p-6">
            <h2 class="text-2xl font-bold mb-4">Giá xăng hôm nay tại Việt Nam</h2>

            <div class="overflow-x-auto">
                <table class="min-w-full border border-gray-200 rounded-lg">
                    <thead class="bg-gray-200">
                        <tr>
                            <th class="py-3 px-4 text-left">Mặt hàng</th>
                            <th class="py-3 px-4 text-left">Giá điều chỉnh (<%= VIETNAM.currency %>/lít)</th>
                            <th class="py-3 px-4 text-left">Chênh lệch giá điều chỉnh (<%= VIETNAM.currency %>/lít)</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        <% VIETNAM.data.forEach(item => { %>
                            <tr class="hover:bg-gray-50">
                                <td class="py-3 px-4"><%= item.item %></td>

                                <td class="py-3 px-4">
                                    <%= item.price.toLocaleString() %>
                                </td>

                                <td class="py-3 px-4 
                                    <%= item.deviant >= 0 ? 'text-green-600' : 'text-red-600' %>">
                                    
                                    <%= item.deviant > 0 ? '+' : '' %>
                                    <%= item.deviant.toLocaleString() %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

        </div>

        <div class="bg-white shadow-md rounded-2xl p-6 mt-8">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-bold">
                    Giá xăng hôm nay tại Hoa Kỳ
                </h2>

                <input 
                    list="state-list"
                    type="text" 
                    placeholder="Tìm bang..." 
                    class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    onkeyup="filterStates(this.value)"
                ><datalist id="state-list">
                    <% AMERICA.data.forEach(item => { %>
                        <option value="<%= item.state %>"></option>
                    <% }) %>
                </datalist>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full border border-gray-200 rounded-lg" id="stateTable">
                    <thead class="bg-gray-200">
                        <tr>
                            <th class="py-3 px-4 text-left cursor-pointer" onclick="sortTable(0)">Bang
                                    <span class="sort-icon">
                                        <svg class="w-3 h-3 inline opacity-40" viewBox="0 0 20 20" fill="currentColor">
                                            <path d="M5 8l5-5 5 5H5zM5 12h10l-5 5-5-5z"/>
                                        </svg>
                                    </span>
                            </th>
                            <th class="py-3 px-4 text-left cursor-pointer" onclick="sortTable(1)">Giá xăng (<%= AMERICA.currency %>/gallon)
                                    <span class="sort-icon">
                                        <svg class="w-3 h-3 inline opacity-40" viewBox="0 0 20 20" fill="currentColor">
                                            <path d="M5 8l5-5 5 5H5zM5 12h10l-5 5-5-5z"/>
                                        </svg>
                                    </span>
                            </th>
                            <th class="py-3 px-4 text-left">Thay đổi hàng tuần (<%= AMERICA.currency %>/gallon)</th>
                            <th class="py-3 px-4 text-left">Thay đổi hàng tháng (<%= AMERICA.currency %>/gallon)</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        <% AMERICA.data.forEach(item => { %>
                            <tr class="hover:bg-gray-50">
                                <td class="py-3 px-4"><%= item.state %></td>

                                <td class="py-3 px-4">
                                    <%= item.price.toLocaleString() %>
                                </td>

                                <td class="py-3 px-4 
                                    <%= item.weeklyChange.includes('+') ? 'text-green-600' : 'text-red-600' %>">
                                    <%= item.weeklyChange %>
                                </td>

                                <td class="py-3 px-4 
                                    <%= item.monthlyChange.includes('+') ? 'text-green-600' : 'text-red-600' %>">
                                    <%= item.monthlyChange %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</body>
</html>